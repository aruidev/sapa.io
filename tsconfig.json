{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "rootDir": ".",
    "outDir": "dist",
    "moduleResolution": "Bundler",
    "lib": ["es2022", "dom"],
    "sourceMap": false,
    "noEmitOnError": true,
    "noImplicitAny": true,
    "strict": true
  },
  "include": ["server/**/*.ts", "client/**/*.ts"]
}
